---
// Prime Citation — AEO Agency Services
// White-label Answer Engine Optimization for Agencies

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="White-Label AEO Reports for Agencies"
  description="Prime Citation delivers white-labeled AEO audits so agencies can make their clients citable by AI. 5 reports per month. No overhead. Your brand."
>

<!-- ═══ NAV ═══ -->
<nav class="sticky top-0 z-50 bg-navy-900/90 backdrop-blur-lg border-b border-slate-800/50">
  <div class="container-site flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2">
      <span class="text-xl font-black tracking-tight text-white">PRIME</span>
      <span class="text-xl font-light tracking-tight text-gold-400">Citation</span>
    </a>
    <div class="hidden md:flex items-center gap-6 text-sm font-medium">
      <a href="#how-it-works" class="text-slate-400 hover:text-white transition-colors">How It Works</a>
      <a href="#pricing" class="text-slate-400 hover:text-white transition-colors">Pricing</a>
      <a href="#faq" class="text-slate-400 hover:text-white transition-colors">FAQ</a>
      <a href="#contact" class="px-5 py-2 rounded-xl bg-accent text-white font-semibold hover:bg-accent-dark transition-colors">Get Started</a>
    </div>
  </div>
</nav>

<!-- ═══ HERO ═══ -->
<header class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-accent/5 via-transparent to-transparent pointer-events-none"></div>
  <div class="container-site py-24 md:py-32 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold-400 mb-4">
        Agency Partnership
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-[1.05]">
        Make Your Clients<br />
        <span class="text-gradient">Citable by AI</span><br />
        Without Doing the Work.
      </h1>
      <p class="mt-6 text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Prime Citation gives you 5 white-labeled AEO audits per month so you can deliver
        premium AI visibility services to your clients while we do all the heavy lifting.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#pricing" class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-accent text-white font-bold text-lg shadow-lg shadow-blue-600/25 hover:bg-accent-dark transition-all">
          Subscribe — $797/mo
        </a>
        <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-4 rounded-xl border border-slate-700 text-slate-400 font-semibold hover:text-white hover:border-accent transition-all">
          How It Works
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-xs text-slate-500">
        <span class="flex items-center gap-1.5"><span class="text-accent">&#10003;</span> White-label — your brand only</span>
        <span class="flex items-center gap-1.5"><span class="text-accent">&#10003;</span> 5 reports per month</span>
        <span class="flex items-center gap-1.5"><span class="text-accent">&#10003;</span> Founders Circle rate locked</span>
      </div>
    </div>
  </div>
</header>

<!-- ═══ HOW IT WORKS ═══ -->
<section id="how-it-works" class="container-site py-20">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center tracking-tight">
      Three Steps. <span class="text-gradient">Zero Overhead.</span>
    </h2>
    <div class="mt-12 grid md:grid-cols-3 gap-6">
      <div class="card-surface flex flex-col items-center text-center p-6">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-accent/20 text-accent font-black text-lg mb-4">1</span>
        <h3 class="text-lg font-bold mb-2">We Run Deep AEO Audits</h3>
        <p class="text-sm text-slate-400 leading-relaxed">We crawl your clients' sites using the Prime Citation pipeline — schema validation, entity coverage maps, semantic gap analysis, and competitive benchmarking.</p>
      </div>
      <div class="card-surface flex flex-col items-center text-center p-6">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-accent/20 text-accent font-black text-lg mb-4">2</span>
        <h3 class="text-lg font-bold mb-2">You Receive White-Label Reports</h3>
        <p class="text-sm text-slate-400 leading-relaxed">Every report ships clean — no Prime Citation branding in the body. Your logo, your presentation, your client relationship protected.</p>
      </div>
      <div class="card-surface flex flex-col items-center text-center p-6">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-accent/20 text-accent font-black text-lg mb-4">3</span>
        <h3 class="text-lg font-bold mb-2">Your Team Presents & Closes</h3>
        <p class="text-sm text-slate-400 leading-relaxed">You add strategic recommendations on top of the technical data. We stay invisible. You own the relationship and the revenue.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ WHAT'S IN A REPORT ═══ -->
<section class="bg-navy-800/30 border-y border-slate-800/50 py-20">
  <div class="container-site">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-black text-center tracking-tight mb-4">
        Every <span class="text-gradient">Prime Citation</span> Report Includes
      </h2>
      <p class="text-center text-slate-400 mb-10 max-w-lg mx-auto">Full technical diagnostics across 8 dimensions — everything an agency needs to deliver real AEO value.</p>
      <div class="grid md:grid-cols-2 gap-3">
        {["Full site crawl with broken link and redirect analysis","Schema.org JSON-LD audit across all relevant entity types","Entity coverage mapping (Organization, Person, Product, FAQ, LocalBusiness)","Semantic HTML5 structure review","Core Web Vitals snapshot","Content heading hierarchy analysis","Competitive entity benchmarking against top 3 competitors","Deployable JSON-LD markup with prioritized content briefs"].map(item => (
          <div class="flex items-start gap-3 text-sm text-slate-300 p-4 card-surface">
            <span class="text-accent mt-0.5">&#10003;</span>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ═══ PRICING ═══ -->
<section id="pricing" class="container-site py-20">
  <div class="max-w-lg mx-auto text-center">
    <div class="card-surface glow-border ring-1 ring-accent/30 p-8">
      <span class="inline-block px-3 py-1 mb-4 rounded-full bg-accent/20 text-accent text-xs font-bold uppercase tracking-wider">Founders Circle</span>
      <h3 class="text-xl font-bold">Prime Citation</h3>
      <div class="mt-4">
        <span class="text-4xl font-black">$797</span>
        <span class="text-slate-400"> /month</span>
      </div>
      <p class="mt-2 text-xs text-slate-400">Founders Circle rate locked through October 2026</p>
      <p class="mt-1 text-xs text-slate-500">Then $1,399/month standard pricing</p>
      <ul class="mt-6 space-y-2.5 text-sm text-slate-400 text-left">
        <li class="flex items-start gap-2"><span class="text-accent mt-0.5">&#10003;</span> <span><strong class="text-white">5</strong> full reports per month</span></li>
        <li class="flex items-start gap-2"><span class="text-accent mt-0.5">&#10003;</span> <span>Extra reports: <strong class="text-white">$349</strong> each</span></li>
        <li class="flex items-start gap-2"><span class="text-accent mt-0.5">&#10003;</span> <span>White-label portal with full report history</span></li>
        <li class="flex items-start gap-2"><span class="text-accent mt-0.5">&#10003;</span> <span>48-72 hour turnaround per report</span></li>
      </ul>
      <a href="#" class="mt-8 inline-flex items-center justify-center w-full px-6 py-3 rounded-xl bg-accent text-white font-bold text-sm hover:bg-accent-dark transition-all shadow-lg shadow-blue-600/25">
        Subscribe — $797/mo
      </a>
      <p class="mt-3 text-xs text-slate-500">Founders Circle rate locked. Cancel anytime.</p>
    </div>
  </div>
</section>

<!-- ═══ BENEFITS ═══ -->
<section class="bg-navy-800/30 border-y border-slate-800/50 py-20">
  <div class="container-site">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-black text-center tracking-tight mb-12">
        What Prime Citation <span class="text-gradient">Does for Your Agency</span>
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {["Increase average project value by $1,500-$3,000 per client","Differentiate against competitors who can't deliver technical AEO depth","No hiring — pipeline talent included in every subscription","Quarterly benchmarking shows compounding ROI to clients","White-label portal with full report history and client management","Founders Circle priority support and roadmap input"].map(benefit => (
          <div class="flex items-start gap-3 text-sm text-slate-400 p-4 card-surface">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent mt-0.5 flex-shrink-0"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <span>{benefit}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ═══ FAQ ═══ -->
<section id="faq" class="container-site py-20">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-black text-center tracking-tight mb-12">Common Questions</h2>
    <div class="space-y-4">
      {[["Can I resell these reports under my own brand?","Yes — Prime Citation is explicitly designed for agency white-label use. The PDF ships clean with no Prime Citation branding in the body. You add your strategic recommendations, bill your client at your own rate, and we remain your technical engine."],["What does a full audit cover?","Every report includes: full site crawl with broken link and redirect analysis, Schema.org JSON-LD audit across all relevant entity types, entity coverage mapping, semantic HTML5 structure review, Core Web Vitals snapshot, content heading hierarchy analysis, competitive entity benchmarking, and deployable JSON-LD markup with prioritized content briefs."],["How many reports can I get per month?","Your subscription includes 5 full reports per month. Additional reports are $349 each. Volume discounts available for agencies consistently ordering 10+ reports per month."],["What's the turnaround time?","Standard turnaround is 48-72 hours from report initiation. Rush delivery (24 hours) is available on request."],["What happens after the Founders Circle period?","Founders Circle rate of $797/month is locked for the first 6 months (through October 2026). After that, standard pricing of $1,399/month applies. Founders Circle members retain priority support and roadmap input for the lifetime of their subscription."]].map(faq => (
        <details class="card-surface group">
          <summary class="flex items-center justify-between cursor-pointer p-4 text-sm font-semibold text-white">
            {faq[0]}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="px-4 pb-4 text-sm text-slate-400 leading-relaxed">{faq[1]}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- ═══ CTA ═══ -->
<section id="contact" class="bg-navy-800/30 border-y border-slate-800/50 py-20 text-center">
  <div class="container-site">
    <h2 class="text-3xl font-black tracking-tight">
      Ready to Add <span class="text-gradient">$1,500-$3,000</span> Per Client?
    </h2>
    <p class="mt-4 text-slate-400 max-w-lg mx-auto">Start your 14-day free trial. No credit card required.</p>
    <a href="#pricing" class="mt-8 inline-flex items-center justify-center px-8 py-4 rounded-xl bg-accent text-white font-bold text-lg shadow-lg shadow-blue-600/25 hover:bg-accent-dark transition-all">
      Subscribe — $797/mo
    </a>
  </div>
</section>

<!-- ═══ FOOTER ═══ -->
<footer class="container-site py-10 text-center text-xs text-slate-500">
  <div class="flex flex-wrap items-center justify-center gap-6 mb-4 text-sm">
    <a href="/blog" class="text-slate-400 hover:text-accent transition-colors">Blog</a>
    <a href="/privacy" class="text-slate-400 hover:text-accent transition-colors">Privacy</a>
    <a href="https://github.com/StarbloomConsultingHub" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-accent transition-colors">GitHub</a>
    <a href="https://medium.com/@darrenkelly_90696" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-accent transition-colors">Medium</a>
  </div>
  <p>&copy; {new Date().getFullYear()} Prime Citation. A Kelly Green Holdings company. All rights reserved.</p>
</footer>

</Layout>
