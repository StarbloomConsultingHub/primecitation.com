---
// Prime Citation — White-Label AEO for Agencies
// Built by an operator. Delivered invisible.

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="White-Label AEO Reports for Agencies"
  description="Prime Citation delivers white-labeled AEO audits so agencies can make their clients citable by AI. 5 reports per month. No overhead. Your brand."
>

<!-- ════════════════════════════════
     NAV
     ════════════════════════════════ -->
<nav class="sticky top-0 z-50 bg-charcoal-900/90 backdrop-blur-lg border-b border-white/5">
  <div class="container-site flex items-center justify-between h-16">
    <!-- Logo: radical symbol + wordmark -->
    <a href="/" class="flex items-center gap-3">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-bronze-500">
        <path d="M3 16L9 4L15 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M9 4V20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M6 11H12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span class="text-lg font-bold tracking-tight text-cream-50">PrimeCitation</span>
    </a>
    <div class="hidden md:flex items-center gap-8 text-sm font-medium">
      <a href="#how-it-works" class="text-stone-400 hover:text-cream-50 transition-colors">How It Works</a>
      <a href="#pricing" class="text-stone-400 hover:text-cream-50 transition-colors">Pricing</a>
      <a href="#faq" class="text-stone-400 hover:text-cream-50 transition-colors">FAQ</a>
      <a href="#contact" class="px-5 py-2.5 rounded-lg bg-bronze-500 text-cream-50 font-semibold hover:bg-bronze-400 transition-colors text-sm">Book a Strategy Call</a>
    </div>
  </div>
</nav>

<!-- ════════════════════════════════
     HERO
     ════════════════════════════════ -->
<header class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bronze-500/5 via-transparent to-transparent pointer-events-none"></div>
  <div class="container-site py-24 md:py-32 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-bronze-400 mb-4">
        White-Label for Legacy Agencies
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-[1.05]" style="font-family: 'DM Sans', sans-serif;">
        Make Your Clients<br />
        <span class="text-grad-bronze">Citable by AI</span><br />
        Without Doing the Work.
      </h1>
      <p class="mt-6 text-lg text-stone-400 max-w-2xl mx-auto leading-relaxed">
        Prime Citation gives you 5 white-labeled AEO reports per month so you can
        deliver premium AI visibility services to your clients while we stay invisible.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#pricing" class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-bronze-500 text-cream-50 font-bold text-lg hover:bg-bronze-400 transition-all shadow-lg shadow-bronze-500/20">
          Subscribe &mdash; $797/mo
        </a>
        <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-4 rounded-lg border border-stone-600 text-stone-400 font-semibold hover:text-cream-50 hover:border-bronze-500 transition-all">
          How It Works
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-xs text-stone-500">
        <span class="flex items-center gap-1.5"><span class="text-bronze-400">&#10003;</span> White-label &mdash; your brand only</span>
        <span class="flex items-center gap-1.5"><span class="text-bronze-400">&#10003;</span> 5 reports per month</span>
        <span class="flex items-center gap-1.5"><span class="text-bronze-400">&#10003;</span> Founders Circle rate locked</span>
      </div>
    </div>
  </div>
</header>

<!-- ════════════════════════════════
     THE PROBLEM
     ════════════════════════════════ -->
<section class="container-site py-20 md:py-28">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black tracking-tight text-center mb-8" style="font-family: 'DM Sans', sans-serif;">
      The Gap Between SEO and <span class="text-grad-bronze">AI Search</span>
    </h2>
    <div class="text-stone-400 leading-relaxed space-y-5 text-base">
      <p>
        Legacy SEO agencies built their practice on keywords, backlinks, and page authority.
        Those skills still matter, but AI answer engines don't rank pages the same way search engines do.
        They cite sources based on entity authority, structured data, and semantic alignment.
      </p>
      <p>
        Most agencies can talk about AEO. Few can deliver it. That gap is costing them clients and revenue.
      </p>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     WHAT IS PRIMECITATION
     ════════════════════════════════ -->
<section class="bg-navy-900/30 border-y border-white/5 py-20">
  <div class="container-site">
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-black tracking-tight mb-6" style="font-family: 'DM Sans', sans-serif;">
            Your AEO Engine.<br />
            <span class="text-grad-bronze">Invisible to the Client.</span>
          </h2>
          <div class="text-stone-400 leading-relaxed space-y-4">
            <p>
              Prime Citation is a white-label AEO production pipeline. We run deep technical
              audits, generate deployable structured data, and deliver everything in clean,
              unbranded reports your agency puts its name on.
            </p>
            <p>
              Your clients see your expertise. Your competitors see your results.
              No one sees us.
            </p>
          </div>
        </div>
        <div class="card-surface p-8">
          <div class="flex items-center gap-4 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-bronze-500">
              <path d="M3 16L9 4L15 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M9 4V20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span class="text-sm font-bold text-cream-50">The Prime Model</span>
          </div>
          <p class="text-sm text-stone-400 leading-relaxed">
            In mathematics, prime numbers are the fundamental building blocks.
            Every composite number is derived from them. Prime Citations work the same way:
            they are the authoritative sources AI engines build their answers on.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     HOW IT WORKS
     ════════════════════════════════ -->
<section id="how-it-works" class="container-site py-20">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center tracking-tight mb-4" style="font-family: 'DM Sans', sans-serif;">
      How It <span class="text-grad-bronze">Works</span>
    </h2>
    <p class="text-center text-stone-400 mb-12 max-w-lg mx-auto">Three steps. Zero hires. Your brand on every deliverable.</p>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="card-surface flex flex-col items-center text-center p-6">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bronze-500/20 text-bronze-400 font-black text-lg mb-4">1</span>
        <h3 class="text-lg font-bold mb-2 text-cream-50">We Run the Audit</h3>
        <p class="text-sm text-stone-400 leading-relaxed">Full crawl. Schema audit. Entity mapping. Competitive benchmarking. Semantic structure analysis. The whole pipeline.</p>
      </div>
      <div class="card-surface flex flex-col items-center text-center p-6">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bronze-500/20 text-bronze-400 font-black text-lg mb-4">2</span>
        <h3 class="text-lg font-bold mb-2 text-cream-50">You Get the Report</h3>
        <p class="text-sm text-stone-400 leading-relaxed">Clean, white-label PDF. No Prime Citation branding in the body. Your logo, your presentation, your client relationship protected.</p>
      </div>
      <div class="card-surface flex flex-col items-center text-center p-6">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bronze-500/20 text-bronze-400 font-black text-lg mb-4">3</span>
        <h3 class="text-lg font-bold mb-2 text-cream-50">You Close the Upsell</h3>
        <p class="text-sm text-stone-400 leading-relaxed">Add your strategic recommendations on top. Bill at your rate. We stay invisible. You own the relationship and the revenue.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     THE PRIMECITATION STANDARD
     ════════════════════════════════ -->
<section class="bg-navy-900/30 border-y border-white/5 py-20">
  <div class="container-site">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-black tracking-tight mb-4" style="font-family: 'DM Sans', sans-serif;">
        The <span class="text-grad-bronze">Prime Citation</span> Standard
      </h2>
      <p class="text-stone-400 mb-12 max-w-lg mx-auto">Every report covers 8 dimensions of technical AEO depth.</p>
      <div class="grid md:grid-cols-2 gap-3 text-left">
        {[
          "Full site crawl with broken link and redirect analysis",
          "Schema.org JSON-LD audit across all entity types",
          "Entity coverage mapping (Organization, Person, Product, FAQ, LocalBusiness)",
          "Semantic HTML5 structure review",
          "Core Web Vitals snapshot with recommendations",
          "Content heading hierarchy and topical alignment",
          "Competitive entity benchmarking against top 3 competitors",
          "Deployable JSON-LD markup with prioritized content briefs"
        ].map(item => (
          <div class="flex items-start gap-3 text-sm text-stone-400 p-4 card-surface">
            <span class="text-bronze-400 mt-0.5 font-bold">&#10003;</span>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     WHO IT'S FOR
     ════════════════════════════════ -->
<section class="container-site py-20">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-black text-center tracking-tight mb-8" style="font-family: 'DM Sans', sans-serif;">
      Built for <span class="text-grad-bronze">Legacy Agencies</span>
    </h2>
    <div class="grid md:grid-cols-2 gap-4">
      {[
        "You have existing clients paying for SEO",
        "You want to add AEO without hiring",
        "You need premium deliverables you can brand as your own",
        "You're losing pitches to specialists who talk about AI",
        "You want to increase project value by $1,500-$3,000",
        "You value substance over hype"
      ].map(item => (
        <div class="flex items-start gap-3 text-sm text-stone-400 p-4 card-surface">
          <span class="text-bronze-400 mt-0.5 font-bold">&#10003;</span>
          <span>{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     TESTIMONIALS (PLACEHOLDER)
     ════════════════════════════════ -->
<section class="bg-navy-900/30 border-y border-white/5 py-20">
  <div class="container-site">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black tracking-tight mb-12" style="font-family: 'DM Sans', sans-serif;">
        Trusted by <span class="text-grad-bronze">Growing Agencies</span>
      </h2>
      <div class="card-surface p-10">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-bronze-500/30 mx-auto mb-6">
          <path d="M3 21C3 21 4 12 7 9.5C10 7 12 3 12 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M15 21C15 21 16 12 19 9.5C22 7 24 3 24 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <p class="text-stone-400 italic leading-relaxed mb-6 max-w-lg mx-auto">
          "Prime Citation let us add a $2,500 upsell to three existing clients in our first month. The reports are thorough enough that our clients think we built the capability in-house."
        </p>
        <div class="w-12 h-12 rounded-full bg-charcoal-800 mx-auto mb-3"></div>
        <p class="text-sm font-semibold text-cream-50">Agency Partner</p>
        <p class="text-xs text-stone-500">Case study coming soon</p>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     PRICING
     ════════════════════════════════ -->
<section id="pricing" class="container-site py-20">
  <div class="max-w-lg mx-auto text-center">
    <div class="card-surface glow-bronze ring-1 ring-bronze-500/30 p-8">
      <span class="inline-block px-3 py-1 mb-4 rounded-full bg-bronze-500/20 text-bronze-400 text-xs font-bold uppercase tracking-wider">Founders Circle</span>
      <h3 class="text-xl font-bold text-cream-50" style="font-family: 'DM Sans', sans-serif;">Prime Citation</h3>
      <div class="mt-4">
        <span class="text-4xl font-black text-cream-50">$797</span>
        <span class="text-stone-400"> /month</span>
      </div>
      <p class="mt-2 text-xs text-stone-400">Founders Circle rate locked through October 2026</p>
      <p class="mt-1 text-xs text-stone-500">Then $1,399/month standard pricing</p>
      <ul class="mt-6 space-y-2.5 text-sm text-stone-400 text-left">
        <li class="flex items-start gap-2"><span class="text-bronze-400 mt-0.5">&#10003;</span> <span><strong class="text-cream-50">5</strong> full reports per month</span></li>
        <li class="flex items-start gap-2"><span class="text-bronze-400 mt-0.5">&#10003;</span> <span>Extra reports: <strong class="text-cream-50">$349</strong> each</span></li>
        <li class="flex items-start gap-2"><span class="text-bronze-400 mt-0.5">&#10003;</span> <span>White-label portal with full report history</span></li>
        <li class="flex items-start gap-2"><span class="text-bronze-400 mt-0.5">&#10003;</span> <span>48-72 hour turnaround per report</span></li>
      </ul>
      <a href="#" class="mt-8 inline-flex items-center justify-center w-full px-6 py-3 rounded-lg bg-bronze-500 text-cream-50 font-bold text-sm hover:bg-bronze-400 transition-all shadow-lg shadow-bronze-500/20">
        Subscribe &mdash; $797/mo
      </a>
      <p class="mt-3 text-xs text-stone-500">Founders Circle rate locked. Cancel anytime.</p>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     FAQ
     ════════════════════════════════ -->
<section id="faq" class="bg-navy-900/30 border-y border-white/5 py-20">
  <div class="container-site">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-black text-center tracking-tight mb-12" style="font-family: 'DM Sans', sans-serif;">
        Common <span class="text-grad-bronze">Questions</span>
      </h2>
      <div class="space-y-4">
        {[
          ["Can I resell these reports under my own brand?", "Yes. Prime Citation is explicitly designed for agency white-label use. The PDF ships clean with no Prime Citation branding in the body. You add your recommendations, bill your client at your rate, and we remain your technical engine."],
          ["What does a full audit include?", "Every report includes: full site crawl with broken link analysis, Schema.org JSON-LD audit across all relevant entity types, entity coverage mapping, semantic HTML5 structure review, Core Web Vitals snapshot, content heading hierarchy analysis, competitive entity benchmarking, and deployable JSON-LD markup with prioritized content briefs."],
          ["How many reports can I get per month?", "Your subscription includes 5 full reports per month. Additional reports are $349 each."],
          ["What's the turnaround time?", "Standard turnaround is 48-72 hours from report initiation. Rush delivery (24 hours) is available on request."],
          ["What happens after the Founders Circle period?", "Founders Circle rate of $797/month is locked for the first 6 months (through October 2026). After that, standard pricing of $1,399/month applies. Founders Circle members retain priority support and roadmap input for the lifetime of their subscription."]
        ].map(faq => (
          <details class="card-surface group">
            <summary class="flex items-center justify-between cursor-pointer p-4 text-sm font-semibold text-cream-50">
              {faq[0]}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-stone-400 group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="px-4 pb-4 text-sm text-stone-400 leading-relaxed">{faq[1]}</div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     FINAL CTA
     ════════════════════════════════ -->
<section id="contact" class="container-site py-20 md:py-28 text-center">
  <div class="max-w-2xl mx-auto">
    <div class="card-surface p-10 glow-bronze">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-bronze-500 mx-auto mb-6">
        <path d="M3 16L9 4L15 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M9 4V20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M6 11H12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <h2 class="text-3xl md:text-4xl font-black tracking-tight mb-4" style="font-family: 'DM Sans', sans-serif;">
        Ready to Add <span class="text-grad-bronze">$1,500-$3,000</span> Per Client?
      </h2>
      <p class="text-stone-400 max-w-md mx-auto mb-8">Start your Founders Circle subscription. Rate locked through October 2026.</p>
      <a href="#pricing" class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-bronze-500 text-cream-50 font-bold text-lg hover:bg-bronze-400 transition-all shadow-lg shadow-bronze-500/20">
        Subscribe &mdash; $797/mo
      </a>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     FOOTER
     ════════════════════════════════ -->
<footer class="border-t border-white/5 py-10 text-center text-xs text-stone-500">
  <div class="container-site">
    <div class="flex flex-wrap items-center justify-center gap-6 mb-4 text-sm">
      <a href="/blog" class="text-stone-400 hover:text-cream-50 transition-colors">Blog</a>
      <a href="/privacy" class="text-stone-400 hover:text-cream-50 transition-colors">Privacy</a>
      <a href="https://github.com/StarbloomConsultingHub" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-cream-50 transition-colors">GitHub</a>
      <a href="https://medium.com/@darrenkelly_90696" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-cream-50 transition-colors">Medium</a>
      <a href="https://x.com/Starbloom_AI" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-cream-50 transition-colors">X</a>
    </div>
    <p>&copy; {new Date().getFullYear()} Prime Citation. A Kelly Green Holdings company.</p>
  </div>
</footer>

</Layout>
