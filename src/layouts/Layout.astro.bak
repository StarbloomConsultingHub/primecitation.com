---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  faq?: Array<{ question: string; answer: string }>;
}

const { title, description, ogImage = '/og-default.jpg', canonicalURL, faq } = Astro.props;
const siteUrl = canonicalURL ?? Astro.url.href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Prime Citation</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:title" content={`${title} | Prime Citation`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://www.primecitation.com${ogImage}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Prime Citation" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Prime Citation`} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={siteUrl} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Prime Citation",
      "url": "https://primecitation.com",
      "description": "White-label AEO audits and reports for agencies. Make your clients citable by AI.",
      "foundingDate": "2026",
      "founder": {
        "@type": "Person",
        "name": "Darren Kelly"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "hello@primecitation.com",
        "contactType": "sales"
      },
      "sameAs": [
        "https://github.com/StarbloomConsultingHub",
        "https://medium.com/@darrenkelly_90696",
        "https://x.com/Starbloom_AI"
      ]
    })} />

    <!-- WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Prime Citation",
      "url": "https://primecitation.com"
    })} />

    <!-- Product -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Prime Citation AEO Subscription",
      "description": "Monthly white-label AEO audit reports for agencies. 5 reports per month.",
      "offers": {
        "@type": "Offer",
        "price": "997",
        "priceCurrency": "USD",
        "priceValidUntil": "2026-10-31",
        "availability": "https://schema.org/InStock"
      }
    })} />

    <!-- Service -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "White-Label AEO Audit Reports",
      "description": "Monthly white-label AEO audits for agencies: full site crawl, Schema.org JSON-LD audit, entity coverage mapping, heading structure review, Core Web Vitals, content hierarchy, competitive benchmarking, and deployable assets.",
      "provider": {
        "@type": "Organization",
        "name": "Prime Citation",
        "url": "https://primecitation.com"
      },
      "audience": {
        "@type": "Audience",
        "audienceType": "SEO agencies and digital marketing agencies"
      },
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "USD",
        "lowPrice": "997",
        "highPrice": "1497",
        "offerCount": "2",
        "availability": "https://schema.org/InStock"
      }
    })} />

    <!-- FAQPage (injected per-page via faq prop) -->
    {faq && faq.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faq.map(f => ({
          "@type": "Question",
          "name": f.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.answer
          }
        }))
      })} />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
