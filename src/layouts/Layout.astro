---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
}

const { title, description, ogImage = '/og-default.jpg', canonicalURL } = Astro.props;
const siteUrl = canonicalURL ?? Astro.url.href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Prime Citation</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:title" content={`${title} | Prime Citation`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${Astro.site}${ogImage}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Prime Citation" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Prime Citation`} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={siteUrl} />

    <!-- Fonts: Inter (body) + DM Sans (headings - free alternative to Satoshi) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Prime Citation",
      "url": "https://primecitation.com",
      "description": "White-label AEO audits and reports for agencies. Make your clients citable by AI.",
      "foundingDate": "2026",
      "founder": {
        "@type": "Person",
        "name": "Darren Kelly"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "hello@primecitation.com",
        "contactType": "sales"
      },
      "sameAs": [
        "https://github.com/StarbloomConsultingHub",
        "https://medium.com/@darrenkelly_90696"
      ]
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Prime Citation",
      "url": "https://primecitation.com"
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Prime Citation AEO Subscription",
      "description": "Monthly white-label AEO audit reports for agencies. 5 reports per month.",
      "offers": {
        "@type": "Offer",
        "price": "797",
        "priceCurrency": "USD",
        "priceValidUntil": "2026-10-31",
        "availability": "https://schema.org/InStock"
      }
    })} />
  </head>
  <body>
    <div class="mx-auto max-w-7xl">
      <slot />
    </div>
  </body>
</html>
